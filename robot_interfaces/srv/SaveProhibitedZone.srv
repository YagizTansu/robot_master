# Request - Save zone to database
string robot_name
string zone_name
string zone_type  # "polygon" (must be 4 points for rectangle)
float64[] polygon_points  # For polygon zones - must have 8 values (4 points: x1,y1,x2,y2,x3,y3,x4,y4)

---
# Response
bool success
string message
string zone_id  # MongoDB ObjectId
