<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <ReactiveFallback name="MainFallback">
      <Sequence name="NormalNavigation">
        <RecoveryNode number_of_retries="2" name="NavigateRecovery">
          <PipelineSequence name="NavigateWithReplanning">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GraphPlanner"
              error_code_id="{compute_path_error_code}" />
            <SmoothPath unsmoothed_path="{path}" smoothed_path="{path}"
              smoother_id="simple_smoother" error_code_id="{smoother_error_code}" />
            <RecoveryNode number_of_retries="1" name="FollowPath">
              <FollowPath path="{path}" controller_id="FollowPath"
                error_code_id="{follow_path_error_code}" />
              <Sequence>
                <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}" />
                <ClearEntireCostmap name="ClearLocalCostmap-Context"
                  service_name="local_costmap/clear_entirely_local_costmap" />
              </Sequence>
            </RecoveryNode>
          </PipelineSequence>
          <Sequence>
            <Fallback>
              <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}" />
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}" />
            </Fallback>
            <ReactiveFallback name="RecoveryFallback">
              <GoalUpdated />
              <RoundRobin name="RecoveryActions">
                <Sequence name="ClearingActions">
                  <ClearEntireCostmap name="ClearLocalCostmap-Subtree"
                    service_name="local_costmap/clear_entirely_local_costmap" />
                  <ClearEntireCostmap name="ClearGlobalCostmap-Subtree"
                    service_name="global_costmap/clear_entirely_global_costmap" />
                </Sequence>
                <BackUp backup_dist="0.30" backup_speed="0.15" error_code_id="{backup_code_id}" />
                <Wait wait_duration="5.0" />
                <Spin spin_dist="1.57" error_code_id="{spin_error_code}" />
              </RoundRobin>
            </ReactiveFallback>
          </Sequence>
        </RecoveryNode>
      </Sequence>
    </ReactiveFallback>
  </BehaviorTree>

</root>